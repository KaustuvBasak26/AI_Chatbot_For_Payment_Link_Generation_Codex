LLM_PROVIDER=none
OPENAI_DEFAULT_MODEL=
OPENAI_API_KEY=
ALLOW_USER_PROVIDED_LLM_KEYS=true
ALLOW_SERVER_LLM_KEY=true
LLM_REQUEST_TIMEOUT_SECONDS=20
LLM_MAX_CONTEXT_MESSAGES=10
LLM_MAX_PROMPT_LENGTH=5000
SUPPORTED_CURRENCIES=INR


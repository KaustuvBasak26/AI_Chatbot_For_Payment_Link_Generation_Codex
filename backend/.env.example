APP_NAME=PayLink Assistant
APP_ENV=development
DATABASE_URL=sqlite:///./paylink.db
FRONTEND_ORIGIN=http://localhost:5173
APP_TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
PAYMENT_PROVIDER=mock
MOCK_PAYMENT_BASE_URL=http://localhost:5173/pay/mock
RAZORPAY_KEY_ID=
